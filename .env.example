# Required: choose the provider/model you want CrewAI to use.
# OpenAI example:
OPENAI_API_KEY=replace_me
MODEL=gpt-4o-mini

# Optional AI provider.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest

# Core app services.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cold_outreach
REDIS_URL=redis://localhost:6379/0

# Email providers.
RESEND_API_KEY=
POSTMARK_SERVER_TOKEN=
FROM_EMAIL=Sean <outreach@example.com>
ALERT_EMAIL=seanmurrill@gmail.com

# Research/enrichment providers.
FIRECRAWL_API_KEY=
TAVILY_API_KEY=
BUILTWITH_API_KEY=
APOLLO_API_KEY=
HUNTER_API_KEY=
CLEARBIT_API_KEY=
LINKEDIN_ENRICHMENT_API_KEY=

# Notification channels.
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
SMS_PROVIDER_API_KEY=

# Optional defaults used by src/cold_outreach_flow/main.py
COMPANY_NAME=Example Defense Manufacturing
CONTACT_NAME=Pat Prospect
CONTACT_ROLE=COO
COMPANY_DOMAIN=example.com
CHANNEL=email
SEQUENCE_POSITION=day_1
PRIMARY_GOAL=Book a 15-minute discovery call for the 90-day Sentinel-CMMC pilot.
KNOWN_CONTEXT=Small GovCon subcontractor pursuing CMMC Level 2 readiness; likely using spreadsheets for readiness tracking.
